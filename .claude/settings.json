{
  "hooks": {
    "PostCompact": [
      {
        "hooks": [
          {
            "args": [
              "hook",
              "post-compact"
            ],
            "command": "hoggit",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "args": [
              "hook",
              "post-tool-use"
            ],
            "command": "hoggit",
            "if": "Bash(git commit *) || Bash(hoggit commit *)",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "args": [
              "hook",
              "pre-compact"
            ],
            "command": "hoggit",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "args": [
              "hook",
              "pre-tool-use"
            ],
            "command": "hoggit",
            "if": "Bash(git commit *) || Bash(hoggit commit *)",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "args": [
              "hook",
              "session-end"
            ],
            "command": "hoggit",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "args": [
              "hook",
              "session-start"
            ],
            "command": "hoggit",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "args": [
              "hook",
              "stop"
            ],
            "command": "hoggit",
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "args": [
              "hook",
              "subagent-stop"
            ],
            "command": "hoggit",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "args": [
              "hook",
              "task-completed"
            ],
            "command": "hoggit",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "args": [
              "hook",
              "task-created"
            ],
            "command": "hoggit",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "args": [
              "hook",
              "user-prompt-submit"
            ],
            "command": "hoggit",
            "type": "command"
          }
        ]
      }
    ]
  }
}
