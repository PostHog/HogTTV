{
  "manifest_version": 3,
  "name": "HogTTV",
  "version": "1.0.0",
  "description": "Use your Slack workspace's custom emojis in Google Meet chat",
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://slack.com/*",
    "https://emoji.slack-edge.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content/meet-inject.js"],
      "css": ["content/meet-inject.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "HogTTV"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["content/emoji-picker.css"],
      "matches": ["https://meet.google.com/*"]
    }
  ]
}
